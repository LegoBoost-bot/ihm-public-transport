{
  "version": 8,
  "name": "Public Transport",
  "metadata": {},
  "sources": {
    "stations": {
      "type": "geojson",
      "data": "https://raw.githubusercontent.com/legoboost-bot/ihm-public-transport/master/source.geojson"
    }
  },
  "sprite": [
    {
      "id": "stops",
      "url": "https://raw.githubusercontent.com/legoboost-bot/ihm-public-transport/master/sprites/sprite"
    }
  ],
  "glyphs": "https://israelhikingmap.osm.org.il/fonts/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "pt-icon",
      "type": "symbol",
      "source": "stations",
      "minzoom": 12.5,
      "paint": {
        "text-color": "#0000FF"
      },
      "layout": {
        "text-field": "🚏",
        "text-allow-overlap": true
      }
    },
    {
      "id": "public-transport",
      "type": "symbol",
      "source": "stations",
      "minzoom": 16,
      "layout": {
        "text-field": [
          "get",
          "StationId"
        ],
        "text-allow-overlap": true,
        "text-anchor": "top",
        "text-offset": [0, 0.75]
      }
    }
  ],
  "id": "public-transport"
}
